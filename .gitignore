# Scan/monitor output - keep the folder, ignore generated reports
reports/*
!reports/.gitkeep

# Backups created by "Update definitions"
data/*.bak

# Local/active config (keep the .example template in the repo)
toolkit.config.json

# Python bytecode cache
__pycache__/
*.pyc

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
